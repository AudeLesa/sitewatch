# --- Shovels (paid aggregator API) --------------------------------------
# Get a key at https://www.shovels.ai/api  (docs: https://docs.shovels.ai)
# Without this key the Shovels source is skipped automatically.
SHOVELS_API_KEY=
# Optional: pin a specific Shovels geo id (else bootstrapped from the city's seed ZIP)
SHOVELS_GEO_ID=
# Optional: how many commercial permits to scan per run before classifying (default 8000)
SHOVELS_MAX_RECORDS=

# --- Houston Sold Permits (free WebFOCUS scrape) ------------------------
# These two are the only unknowns left to finalize the free Houston source.
# Discover them with: npm run probe:houston   (see README "Finishing Houston")
HOUSTON_WF_SERVLET=
HOUSTON_WF_EX=

# --- Pipeline knobs -----------------------------------------------------
# Which city preset to pull (only "houston" exists today)
SITEWATCH_CITY=houston
# "Currently under construction" heuristic: keep permits issued within N months
# that haven't been finalized. 24mo is a reasonable commercial build window.
SITEWATCH_LOOKBACK_MONTHS=24
