node_modules/
dist/
.env
*.log
.DS_Store

# Outputs are regenerated by every pull — don't version them...
data/*
# ...but DO version the accumulated state files: they are irreplaceable
# (months of geocodes / TDLR detail pages / project history), they seed the
# CI cache on the first Actions run, and they double as an off-machine backup.
!data/lookups/
!data/geocode-cache.json
!data/tabs-detail-cache.json
!data/history.json
# history-<region>.json are the LIVE per-region stores (history.json is the
# frozen pre-region texas seed) — re-commit them after data runs like the
# other state files.
!data/history-texas.json
!data/history-seattle.json
# Launch-gate artifact: the 50-record human-audit sample for the Seattle region.
!data/seattle-audit-50.md

# wrangler's local cache (created by wrangler login/deploy)
.wrangler/
